# ========================================
# Moonjar PMS — Environment Variables
# ========================================

# --- Database (Supabase) ---
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# --- Security ---
SECRET_KEY=change-this-to-random-64-char-string
SECRET_KEY_PREVIOUS=
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5174,http://localhost:5175
OWNER_KEY=one-time-key-for-first-owner-setup

# --- TOTP 2FA ---
TOTP_ENCRYPTION_KEY=change-this-to-random-32-char-key

# --- Backup ---
BACKUP_ENCRYPTION_KEY=change-this-to-random-passphrase
S3_BACKUP_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1

# --- IP Allowlist ---
ADMIN_IP_ALLOWLIST=

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com

# --- Sales Integration ---
SALES_APP_URL=https://sales.moonjar.com
SALES_APP_API_KEY=
PRODUCTION_WEBHOOK_ENABLED=true
PRODUCTION_WEBHOOK_AUTH_MODE=bearer
PRODUCTION_WEBHOOK_BEARER_TOKEN=
PRODUCTION_WEBHOOK_HMAC_SECRET=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# --- AI ---
OPENAI_API_KEY=sk-xxx

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/api/ws
VITE_USE_MOCK=0
VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
